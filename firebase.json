{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", ".firebaserc", "**/node_modules/**", ".git"],
    "rewrites": [
      { "source": "/api/**", "function": "api" },
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22"
  }
}
