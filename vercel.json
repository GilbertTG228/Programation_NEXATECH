{
  "framework": "vite",
  "buildCommand": "pnpm --filter @workspace/nexatech run build",
  "outputDirectory": "artifacts/nexatech/dist/public",
  "installCommand": "pnpm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
